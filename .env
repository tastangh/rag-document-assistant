RAG_RESULTS_DIR=src/results
RAG_RUNTIME_ROOT=src/results/ui_simple_runtime
RAG_CHUNK_ARTIFACTS_DIR=src/results/chunkEmbeddings
RAG_VECTOR_PERSIST_DIR=src/results/vectorStore/chroma
RAG_EVAL_DIR=src/results/eval
RAG_OCR_CACHE_DIR=src/results/cache/paddlex

RAG_COLLECTION_NAME=rag_chunks_v1
RAG_EMBED_MODEL_NAME=./models/newmindai__Mursit-Large-TR-Retrieval
RAG_RERANK_MODEL_NAME=./models/BAAI__bge-reranker-v2-m3

# Docker icinden host'taki Ollama'ya erisim
RAG_OLLAMA_URL=http://host.docker.internal:11434/api/generate
RAG_OLLAMA_MODEL=qwen3:8b

RAG_GUARDRAIL_MODEL=./models/newmindai__ettin-encoder-150M-TR-HD
RAG_GUARDRAIL_THRESHOLD=0.55

# GPU odakli calisma
RAG_OCR_USE_GPU=1
RAG_EMBED_DEVICE=cuda
RAG_RETRIEVAL_DEVICE=cuda
CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# HF cache/offline hizlandirma
HF_HOME=/app/src/results/cache/huggingface
TRANSFORMERS_CACHE=/app/src/results/cache/huggingface/transformers
SENTENCE_TRANSFORMERS_HOME=/app/src/results/cache/huggingface/sentence_transformers
HF_HUB_DISABLE_TELEMETRY=1
HF_HUB_ENABLE_HF_TRANSFER=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# Torch performans
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
